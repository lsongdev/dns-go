$ORIGIN example.com.
$TTL 3600

@           IN  SOA  ns1.example.com. admin.example.com. (
                     2026010101 ; serial
                     7200       ; refresh
                     3600       ; retry
                     1209600    ; expire
                     3600 )     ; minimum

@           IN  NS   ns1.example.com.
@           IN  A    192.168.1.1
@           IN  AAAA fd00::1
@           IN  MX   10 mail.example.com.

ns1         IN  A    192.168.1.1
mail        IN  A    192.168.1.2
nas         IN  A    192.168.1.100
printer     IN  A    192.168.1.101
router      IN  A    192.168.1.1
www         IN  CNAME @
